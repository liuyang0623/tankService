# ===========================================
# 环境变量模板 — 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ===========================================

# 数据库配置（docker-compose 和应用共用）
DB_ROOT_PASSWORD=your_root_password
DB_NAME=go_service_db
DB_USER=root
DB_PASSWORD=your_password
DB_PORT=3307
DATABASE_URL="root:your_password@tcp(127.0.0.1:3307)/go_service_db?charset=utf8mb4&parseTime=True&loc=Local"

# JWT 配置
JWT_SECRET=your_jwt_secret

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 又拍云配置
UPYUN_BUCKET=your_bucket
UPYUN_DOMAIN=https://your-upyun-domain.com
UPYUN_OPERATOR=your_operator
UPYUN_PASSWORD=your_upyun_password
UPYUN_ENDPOINT=v0.api.upyun.com

# 应用配置
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000
